YNAB_ACCESS_TOKEN=
YNAB_BUDGET_ID=

# Google Calendar Integration (Temporal Correlation)
GOOGLE_CALENDAR_ID=
# Provide GOOGLE_API_KEY for public calendars, or GOOGLE_APPLICATION_CREDENTIALS path for private ones
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
BRAVE_API_KEY=

# Identity Resolution (TASK-4)
GOOGLE_SEARCH_ENGINE_ID=
# AI SDK Configuration (Supports provider:model format)
# Providers: openai, google, anthropic
# Examples:
# AI_MODEL=openai:gpt-4o-mini
# AI_MODEL=google:gemini-1.5-pro
# AI_MODEL=anthropic:claude-3-haiku-20240307
AI_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL= # For OpenRouter, Ollama, vLLM, etc.
OPEN_ROUTER_API_KEY=

# Gmail Integration (TASK-13 - Transaction Email Enrichment)
# Download OAuth 2.0 client credentials (Desktop app) from Google Cloud Console
# and save to the path below. Then run: npm run gmail:auth
GMAIL_OAUTH_CLIENT=secrets/gmail-oauth-client.json
GMAIL_TOKEN_PATH=secrets/gmail-token.json
